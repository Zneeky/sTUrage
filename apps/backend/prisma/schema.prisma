// ============================================================
// STURage — Prisma Schema
// STUR-6 | Sprint 1
//
// This file is the single source of truth for the database.
// After every change:
//   npx prisma migrate dev --name <description>
//   npx prisma generate
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────

// Role controls what a user can do in the API.
// ADMIN    — full access including user management and deletions
// MANAGER  — create/edit products, categories, suppliers, stock movements
// OPERATOR — create stock movements only
// VIEWER   — read-only access across all resources
enum Role {
  ADMIN
  MANAGER
  OPERATOR
  VIEWER
}

// MovementType describes the direction and intent of a stock change.
// INBOUND   — product arrives at a warehouse (purchase, return)
// OUTBOUND  — product leaves a warehouse (sale, consumption)
// TRANSFER  — product moves between two warehouses
// ADJUSTMENT — manual correction (count discrepancy, damage write-off)
enum MovementType {
  INBOUND
  OUTBOUND
  TRANSFER
  ADJUSTMENT
}

// ── Models ───────────────────────────────────────────────────

// User — system account; soft-deleted via isActive
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // bcrypt hash, cost factor 10 — never return this field in API responses
  firstName String
  lastName  String
  role      Role     @default(OPERATOR)
  isActive  Boolean  @default(true) // false = soft-deleted; filter with where: { isActive: true }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stockMovements StockMovement[] // movements this user created

  @@map("users")
}

// Category — product classification; name must be unique
model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@map("categories")
}

// Supplier — vendor that provides products; optional on Product
model Supplier {
  id          String   @id @default(cuid())
  name        String
  contactName String?
  email       String?
  phone       String?
  address     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@map("suppliers")
}

// Warehouse — physical storage location
// One warehouse can hold many products (via StockItem)
model Warehouse {
  id          String   @id @default(cuid())
  name        String
  location    String   // human-readable location, e.g. "Building A, Floor 2"
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  inventory StockItem[]

  @@map("warehouses")
}

// Product — a stock-keeping unit (SKU) in the system
// Each product belongs to one category and optionally one supplier.
// Actual quantities are stored in StockItem (per warehouse).
model Product {
  id          String   @id @default(cuid())
  sku         String   @unique // e.g. "ELEC-001" — must be unique across all products
  name        String
  description String?
  unit        String   @default("pcs") // unit of measure: pcs, kg, l, m, box, etc.
  minStock    Int      @default(0)     // low-stock threshold; alert when StockItem.quantity < minStock
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryId String
  category   Category  @relation(fields: [categoryId], references: [id])

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  stockItems     StockItem[]
  stockMovements StockMovement[]

  @@map("products")
}

// StockItem — current quantity of a product at a specific warehouse.
// This is a derived aggregate, kept in sync by StockMovement creation.
// IMPORTANT: always update StockItem inside the same prisma.$transaction as the StockMovement.
// Unique constraint ensures one record per (product, warehouse) pair.
model StockItem {
  id        String   @id @default(cuid())
  quantity  Int      @default(0) // must never go negative; validate before OUTBOUND movements
  updatedAt DateTime @updatedAt

  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId]) // one stock record per product-warehouse pair
  @@map("stock_items")
}

// StockMovement — immutable audit log of every quantity change.
// Records are NEVER updated or deleted. Use ADJUSTMENT type to correct errors.
//
// Field usage by type:
//   INBOUND:    quantity > 0, targetWarehouseId required, sourceWarehouseId null
//   OUTBOUND:   quantity > 0, sourceWarehouseId required, targetWarehouseId null
//   TRANSFER:   quantity > 0, both sourceWarehouseId and targetWarehouseId required
//   ADJUSTMENT: quantity can be positive or negative, at least one warehouse required
model StockMovement {
  id        String       @id @default(cuid())
  type      MovementType
  quantity  Int          // always positive; direction is inferred from type
  note      String?      // optional reason / reference (e.g. "PO #1234", "Damaged goods")
  createdAt DateTime     @default(now()) // immutable — no updatedAt

  productId         String
  product           Product @relation(fields: [productId], references: [id])

  createdById       String
  createdBy         User    @relation(fields: [createdById], references: [id])

  // Warehouse references stored as raw IDs (not FK relations) to keep query flexibility.
  // Validate their existence in the service layer before writing.
  sourceWarehouseId String? // required for OUTBOUND and TRANSFER
  targetWarehouseId String? // required for INBOUND and TRANSFER

  @@map("stock_movements")
}
